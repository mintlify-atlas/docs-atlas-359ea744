  "keyFeatures": [
    "Double-precision (64-bit) and single-precision (32-bit) vector and matrix types",
    "Quaternion rotations with Slerp, Nlerp, Euler, and axis-angle support",
    "Comprehensive bounding volumes: AABB, Sphere, Frustum, Plane, Cone, Ray, Triangle",
    "GJK collision detection for any IBoundingShape",
    "Extensive intersection tests: ray-triangle, ray-AABB, sphere-sphere, frustum culling",
    "Procedural mesh system (GeometryData) with generators, boolean CSG, and operators",
    "Simplex, Perlin, periodic, and cellular (Worley) noise functions",
    "xoshiro256** RNG with geometry helpers (OnUnitSphere, NextGaussian, etc.)",
    "Full GLSL-style swizzle support on all vector types",
    "Unity-inspired API for familiar game engine workflow",
    "NuGet-packaged library targeting .NET 6/7/8/9/10 and netstandard2.1"
  ],
  "publicApiSurface": [
    "Double2, Double3, Double4 (double-precision 2D/3D/4D vectors)",
    "Float2, Float3, Float4 (single-precision 2D/3D/4D vectors)",
    "Int2, Int3, Int4 (integer 2D/3D/4D vectors)",
    "Double4x4, Double3x3, Double2x2 (double-precision matrices)",
    "Float4x4, Float3x3, Float2x2 (single-precision matrices)",
    "Quaternion",
    "Color, Color32, Colors",
    "Rect, IntRect",
    "AABB, Frustum, Plane, Ray, Sphere, Cone, Triangle, LineSegment",
    "Spline, SplineFrame",
    "Transform2D, Transform3D",
    "IBoundingShape",
    "GJK.Intersects(IBoundingShape, IBoundingShape)",
    "Intersection (static class with RayPlane, RayTriangle, RayAABB, SphereSphere, etc.)",
    "GeometryData (mesh representation with Vertex, Edge, Loop, Face)",
    "GeometryGenerator.Box / Sphere / Cylinder / Plane / ...",
    "GeometryOperators (Subdivide, Extrude, Inset, Bevel, Merge, SplitFace, Weld, etc.)",
    "GeometryCSG.Union / Intersection / Subtraction",
    "Noise.SNoise(Float2/3/4), Noise.CNoise(Float2/3/4), Noise.PNoise, Noise.Cellular2D/3D",
    "RNG (xoshiro256**), RNG.Shared",
    "Maths (static constants and functions: Lerp, Clamp, Remap, Floor, Abs, etc.)"
  ]
